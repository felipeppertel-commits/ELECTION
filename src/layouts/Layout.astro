---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Pesquisas eleitorais + termômetro social das eleições brasileiras 2026" } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — Eleições 2026</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300..700;1,9..40,300..700&family=DM+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <nav class="nav">
      <a href="/" class="nav-logo">
        <span class="logo-icon">🗳️</span>
        <span class="logo-text">Eleições <strong>2026</strong></span>
      </a>
      <div class="nav-links">
        <a href="/" class="nav-link active">Mapa</a>
        <a href="#presidente" class="nav-link">Presidente</a>
        <a href="#buzz" class="nav-link">Termômetro</a>
      </div>
      <div class="nav-meta">
        Atualizado a cada 6h
        <span class="pulse"></span>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <p>
        Dados: Google Trends, Bluesky, Google News, Wikipedia.
        Pesquisas registradas no TSE.
        Projeto open source — sem vínculo partidário.
      </p>
    </footer>

    <style is:global>
      :root {
        --bg-primary: #0a0a0f;
        --bg-secondary: #12121a;
        --bg-tertiary: #1a1a25;
        --bg-card: #16161f;
        --text-primary: #e8e6e1;
        --text-secondary: #9c9a92;
        --text-tertiary: #6a6960;
        --accent: #3b82f6;
        --accent-dim: rgba(59, 130, 246, 0.15);
        --positive: #22c55e;
        --positive-dim: rgba(34, 197, 94, 0.15);
        --negative: #ef4444;
        --negative-dim: rgba(239, 68, 68, 0.15);
        --neutral: #eab308;
        --neutral-dim: rgba(234, 179, 8, 0.15);
        --border: rgba(255, 255, 255, 0.06);
        --border-hover: rgba(255, 255, 255, 0.12);
        --radius: 12px;
        --radius-sm: 8px;
        --font-sans: "DM Sans", system-ui, sans-serif;
        --font-mono: "DM Mono", monospace;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        font-family: var(--font-sans);
        background: var(--bg-primary);
        color: var(--text-primary);
        -webkit-font-smoothing: antialiased;
      }

      body {
        min-height: 100vh;
      }

      main {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
      }

      a {
        color: var(--accent);
        text-decoration: none;
      }

      /* Nav */
      .nav {
        display: flex;
        align-items: center;
        gap: 2rem;
        padding: 1rem 2rem;
        border-bottom: 1px solid var(--border);
        backdrop-filter: blur(12px);
        position: sticky;
        top: 0;
        z-index: 100;
        background: rgba(10, 10, 15, 0.85);
      }

      .nav-logo {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--text-primary);
        font-size: 1.1rem;
        letter-spacing: -0.02em;
      }

      .logo-icon { font-size: 1.4rem; }
      .logo-text strong { color: var(--accent); }

      .nav-links {
        display: flex;
        gap: 0.25rem;
      }

      .nav-link {
        padding: 0.4rem 0.8rem;
        border-radius: var(--radius-sm);
        color: var(--text-secondary);
        font-size: 0.875rem;
        transition: all 0.15s;
      }

      .nav-link:hover, .nav-link.active {
        color: var(--text-primary);
        background: var(--bg-tertiary);
      }

      .nav-meta {
        margin-left: auto;
        font-size: 0.75rem;
        color: var(--text-tertiary);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-mono);
      }

      .pulse {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--positive);
        animation: pulse 2s infinite;
      }

      @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.3; }
      }

      /* Cards */
      .card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1.5rem;
        transition: border-color 0.15s;
      }

      .card:hover {
        border-color: var(--border-hover);
      }

      /* Section headers */
      .section-title {
        font-size: 0.7rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--text-tertiary);
        margin-bottom: 1rem;
        font-family: var(--font-mono);
      }

      /* Footer */
      .footer {
        max-width: 1200px;
        margin: 4rem auto 2rem;
        padding: 1.5rem 2rem;
        border-top: 1px solid var(--border);
        font-size: 0.8rem;
        color: var(--text-tertiary);
        line-height: 1.6;
      }

      /* Utility */
      .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
      .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; }
      .flex-between { display: flex; justify-content: space-between; align-items: center; }
      .mono { font-family: var(--font-mono); }

      @media (max-width: 768px) {
        .grid-2, .grid-3 { grid-template-columns: 1fr; }
        .nav { flex-wrap: wrap; padding: 0.75rem 1rem; gap: 0.75rem; }
        .nav-meta { display: none; }
        main { padding: 1rem; }
      }
    </style>
  </body>
</html>
