---
import Layout from "../../layouts/Layout.astro";
import CandidateRanking from "../../components/CandidateRanking";
import BuzzThermometer from "../../components/BuzzThermometer";
import { getGovernadorRanking, getBuzzRanking } from "../../lib/data";
import { UF_NAMES } from "../../lib/types";

export function getStaticPaths() {
  return Object.keys(UF_NAMES).map((uf) => ({
    params: { uf: uf.toLowerCase() },
  }));
}

const { uf } = Astro.params;
const ufUpper = uf!.toUpperCase();
const stateName = UF_NAMES[ufUpper] ?? ufUpper;

const [governadores, buzz] = await Promise.all([
  getGovernadorRanking(ufUpper),
  getBuzzRanking("governador"),
]);

// Filter buzz to this state
const stateBuzz = buzz.filter((b) => b.uf === ufUpper);
---

<Layout title={`${stateName} (${ufUpper})`}>
  <section class="state-hero">
    <a href="/" class="back-link">← Voltar ao mapa</a>
    <h1>{stateName} <span class="uf-badge">{ufUpper}</span></h1>
    <p class="state-sub">Corrida para governador — pesquisas + termômetro social</p>
  </section>

  {governadores.length > 0 ? (
    <section class="section">
      <div class="grid-2">
        <div class="card">
          <CandidateRanking
            client:load
            candidates={governadores}
            title={`Governador ${ufUpper} — Média Ponderada`}
            showAvgType="ponderada"
          />
        </div>
        <div class="card">
          <CandidateRanking
            client:load
            candidates={governadores}
            title={`Governador ${ufUpper} — Média Simples`}
            showAvgType="simples"
          />
        </div>
      </div>
    </section>
  ) : (
    <section class="section">
      <div class="card empty-state">
        <p>Ainda não há pesquisas registradas para governador de {stateName}.</p>
        <p class="empty-hint">
          Dados serão adicionados automaticamente conforme pesquisas forem publicadas.
        </p>
      </div>
    </section>
  )}

  {stateBuzz.length > 0 && (
    <section class="section">
      <h2 class="section-title">Termômetro Social — Governador {ufUpper}</h2>
      <BuzzThermometer client:load candidates={stateBuzz} />
    </section>
  )}
</Layout>

<style>
  .state-hero {
    padding: 1rem 0 0;
  }

  .back-link {
    font-size: 0.8rem;
    font-family: var(--font-mono);
    color: var(--text-tertiary);
    display: inline-block;
    margin-bottom: 0.75rem;
    transition: color 0.15s;
  }

  .back-link:hover {
    color: var(--accent);
  }

  .state-hero h1 {
    font-size: 2rem;
    font-weight: 300;
    letter-spacing: -0.02em;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .uf-badge {
    font-size: 0.9rem;
    font-family: var(--font-mono);
    font-weight: 600;
    background: var(--accent-dim);
    color: var(--accent);
    padding: 0.2rem 0.6rem;
    border-radius: 6px;
  }

  .state-sub {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-top: 0.4rem;
  }

  .section {
    margin-top: 2rem;
  }

  .empty-state {
    padding: 3rem 2rem;
    text-align: center;
    color: var(--text-secondary);
  }

  .empty-hint {
    font-size: 0.8rem;
    color: var(--text-tertiary);
    margin-top: 0.5rem;
  }
</style>
