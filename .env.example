# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# YouTube Data API v3 (free tier: 10k units/day)
YOUTUBE_API_KEY=your-youtube-api-key

# Vercel Deploy Hook (for triggering rebuilds after data collection)
VERCEL_DEPLOY_HOOK=https://api.vercel.com/v1/integrations/deploy/your-hook-id

# Optional: Override cron schedule (default: every 6 hours)
# CRON_SCHEDULE="0 */6 * * *"
